# Example environment variables for SafeHavenConnect

# --- Database Configuration ---
# For MySQL:
# DATABASE_URL=mysql+pymysql://username:password@hostname:3306/database_name
# For PostgreSQL:
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name
DATABASE_URL=postgresql://postgres:password@your-db-host.amazonaws.com:5432/postgres

# --- Flask Configuration ---
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here

# --- Server Configuration ---
PORT=5000
